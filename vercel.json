{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" }
  ]
}
