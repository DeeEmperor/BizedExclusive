# Environment Variables

Copy this file to `.env` and fill in your values.

# Admin password for the /admin dashboard
ADMIN_PASSWORD=bized2024admin

# Session secret (change this to a long random string in production)
SESSION_SECRET=change-me-to-a-long-random-secret

# Database URL (if/when you switch to Postgres)
# DATABASE_URL=postgresql://user:password@host:5432/bizedexclusive
